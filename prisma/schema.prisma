generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id
  name         String
  email        String        @unique
  password     String
  role         String
  appointments Appointment[]
  orders       Order[]
}

model Doctor {
  id            String        @id
  name          String
  specialty     String
  rating        Float
  image         String
  experience    String
  fee           Int
  appointments  Appointment[]
}

model Medicine {
  id        String      @id
  name      String
  price     Int
  category  String
  stock     Int
  image     String
  orderItems OrderItem[]
}

model Appointment {
  id        String   @id
  userId    String
  doctorId  String
  date      String
  time      String
  status    String

  user       User    @relation(fields: [userId], references: [id])
  doctor     Doctor  @relation(fields: [doctorId], references: [id])
}

model Order {
  id        String      @id
  userId    String
  total     Int
  date      DateTime
  status    String

  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  id          Int       @id @default(autoincrement())
  orderId     String
  medicineId  String
  quantity    Int

  order       Order     @relation(fields: [orderId], references: [id])
  medicine    Medicine  @relation(fields: [medicineId], references: [id])
}